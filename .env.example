VITE_AIRTABLE_TOKEN=your_token_here
VITE_AIRTABLE_BASE=your_base_id_here
VITE_AIRTABLE_TABLE=your_table_id_here

# Supabase Auth (required for /product sign-in in production)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API base URL
# Local dev: omit or use /api (Vite proxy to localhost:8000)
# Production (Vercel): set in Vercel env vars — NOT in this file
# VITE_API_BASE_URL=https://api.yourdomain.com/api
